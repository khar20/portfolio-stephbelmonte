---
const subsections = [
    {
        id: "environments",
        label: "Environments",
        tag: "ARCHVIZ",
        items: [
            {
                src: "https://placehold.co/1200x700/111/eee?text=Museum+Interior",
                alt: "Museum Interior",
                caption: "Palazzo Ducale and Biblioteca Marciana",
                wide: true,
            },
            {
                src: "https://placehold.co/800x500/0e0e0e/ccc?text=Guggenheim+Render",
                alt: "Guggenheim Museum",
                caption: "Guggenheim Museum",
                wide: false,
            },
            {
                src: "https://placehold.co/800x500/0a0a0a/bbb?text=Environment+Layout",
                alt: "Environment Layout",
                caption: "Environment Layout Study",
                wide: false,
            },
        ],
    },
    {
        id: "characters",
        label: "Characters",
        tag: "SCULPTING",
        items: [
            {
                src: "https://placehold.co/700x900/111/fff?text=Character+Wireframe",
                alt: "Character Wireframe",
                caption: "Character Wireframe — Clay render",
                wide: false,
                tall: true,
            },
            {
                src: "https://placehold.co/700x900/0d0d0d/ddd?text=Character+Final",
                alt: "Character Final",
                caption: "Character Final — Texture pass",
                wide: false,
                tall: true,
            },
        ],
    },
    {
        id: "props",
        label: "Props & Details",
        tag: "MATERIALS",
        items: [
            {
                src: "https://placehold.co/600x600/111/ccc?text=Prop+Detail",
                alt: "Prop Detail",
                caption: "Prop Detail",
                wide: false,
            },
            {
                src: "https://placehold.co/600x600/0d0d0d/bbb?text=Lighting+Setup",
                alt: "Lighting Setup",
                caption: "Lighting Setup",
                wide: false,
            },
            {
                src: "https://placehold.co/600x600/0a0a0a/aaa?text=Material+Study",
                alt: "Material Study",
                caption: "Material Study — Metal",
                wide: false,
            },
        ],
    },
];
---

<section class="gallery-section" id="gallery">
    <div class="gallery-header container">
        <h2 class="section-title">GALLERY</h2>
        <p class="gallery-intro">
            Selected works across personal and commercial projects.
        </p>
    </div>

    <!-- filter -->
    <div class="filter-bar container">
        <button class="filter-pill active" data-filter="all">ALL</button>
        {
            subsections.map((s) => (
                <button class="filter-pill" data-filter={s.id}>
                    {s.tag}
                </button>
            ))
        }
    </div>

    <div class="gallery-body container">
        {
            subsections.map((sub, si) => (
                <div class="gallery-subsection" data-subsection={sub.id}>
                    <div class="subsection-label">
                        <span class="sub-index">0{si + 1}</span>
                        <div class="sub-title-group">
                            <h3 class="sub-title">{sub.label}</h3>
                            <span class="sub-tag">{sub.tag}</span>
                        </div>
                    </div>
                    <div class={`sub-grid layout-${sub.items.length}`}>
                        {sub.items.map((item) => (
                            <figure
                                class={`gallery-item ${item.wide ? "wide" : ""} ${(item as any).tall ? "tall" : ""}`}
                            >
                                <div class="img-frame">
                                    <img
                                        src={item.src}
                                        alt={item.alt}
                                        loading="lazy"
                                    />
                                </div>
                                <figcaption>{item.caption}</figcaption>
                            </figure>
                        ))}
                    </div>
                    {si < subsections.length - 1 && <div class="sub-divider" />}
                </div>
            ))
        }
    </div>
</section>

<script>
    const pills = Array.from(
        document.querySelectorAll<HTMLElement>(".filter-pill"),
    );
    const subsections = Array.from(
        document.querySelectorAll<HTMLElement>(".gallery-subsection"),
    );

    pills.forEach((pill) => {
        pill.addEventListener("click", () => {
            pills.forEach((p) => p.classList.remove("active"));
            pill.classList.add("active");
            const filter = pill.dataset.filter!;
            subsections.forEach((sub) => {
                if (filter === "all" || sub.dataset.subsection === filter) {
                    sub.style.display = "";
                    sub.style.animation = "fadeSlide 0.4s ease forwards";
                } else {
                    sub.style.display = "none";
                }
            });
        });
    });
</script>

<style>
    .gallery-section {
        padding: 8rem 0 6rem;
        background: var(--bg-color);
    }

    .gallery-header {
        margin-bottom: 3rem;
    }

    .section-title {
        font-family: "Playfair Display", serif;
        font-size: clamp(2.5rem, 7vw, 7rem);
        font-weight: 700;
        letter-spacing: -0.02em;
        line-height: 1;
        margin-bottom: 1rem;
    }

    .gallery-intro {
        font-size: 0.9rem;
        opacity: 0.4;
        font-weight: 300;
        letter-spacing: 0.05em;
    }

    .filter-bar {
        display: flex;
        gap: 0.6rem;
        flex-wrap: wrap;
        margin-bottom: 5rem;
    }

    .filter-pill {
        background: none;
        border: 1px solid rgba(255, 255, 255, 0.15);
        color: var(--text-color);
        padding: 0.4rem 1rem;
        border-radius: 2px;
        font-size: 0.62rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        cursor: pointer;
        transition:
            border-color 0.2s,
            background 0.2s,
            opacity 0.2s;
        opacity: 0.5;
    }

    .filter-pill:hover {
        opacity: 0.8;
        border-color: rgba(255, 255, 255, 0.35);
    }

    .filter-pill.active {
        opacity: 1;
        border-color: var(--text-color);
        background: rgba(255, 255, 255, 0.06);
    }

    .gallery-body {
        display: flex;
        flex-direction: column;
        gap: 0;
    }

    .gallery-subsection {
        animation: fadeSlide 0.4s ease forwards;
    }

    @keyframes fadeSlide {
        from {
            opacity: 0;
            transform: translateY(12px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .subsection-label {
        display: flex;
        align-items: flex-start;
        gap: 1.5rem;
        margin-bottom: 2rem;
    }

    .sub-index {
        font-size: 0.68rem;
        letter-spacing: 0.15em;
        opacity: 0.25;
        padding-top: 0.2rem;
        font-variant-numeric: tabular-nums;
    }

    .sub-title-group {
        display: flex;
        flex-direction: column;
        gap: 0.2rem;
    }

    .sub-title {
        font-size: 1.1rem;
        font-weight: 400;
        letter-spacing: 0.05em;
    }

    .sub-tag {
        font-size: 0.6rem;
        letter-spacing: 0.22em;
        opacity: 0.3;
        text-transform: uppercase;
    }

    .sub-grid {
        display: grid;
        gap: 1rem;
        margin-bottom: 4rem;
    }

    .sub-grid.layout-1 {
        grid-template-columns: 1fr;
    }

    .sub-grid.layout-2 {
        grid-template-columns: 1fr 1fr;
    }

    .sub-grid.layout-3 {
        grid-template-columns: repeat(3, 1fr);
    }

    .gallery-item {
        margin: 0;
    }

    .gallery-item.wide {
        grid-column: 1 / -1;
    }

    .img-frame {
        overflow: hidden;
        border-radius: 2px;
        background: #0d0d0d;
        margin-bottom: 0.6rem;
    }

    .gallery-item.tall .img-frame {
        aspect-ratio: 3 / 4;
    }

    .gallery-item:not(.tall) .img-frame {
        aspect-ratio: 4 / 3;
    }

    .gallery-item.wide .img-frame {
        aspect-ratio: 16 / 9;
    }

    .img-frame img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        filter: grayscale(20%);
        transition:
            transform 0.7s cubic-bezier(0.16, 1, 0.3, 1),
            filter 0.3s ease;
        display: block;
    }

    .gallery-item:hover .img-frame img {
        transform: scale(1.04);
        filter: grayscale(0%);
    }

    figcaption {
        font-size: 0.7rem;
        opacity: 0.35;
        letter-spacing: 0.06em;
        font-weight: 300;
    }

    .sub-divider {
        height: 1px;
        background: rgba(255, 255, 255, 0.07);
        margin-bottom: 4rem;
    }

    /* responsive */
    @media (max-width: 900px) {
        .sub-grid.layout-3 {
            grid-template-columns: 1fr 1fr;
        }
    }

    @media (max-width: 600px) {
        .gallery-section {
            padding: 5rem 0 4rem;
        }
        .sub-grid.layout-2,
        .sub-grid.layout-3 {
            grid-template-columns: 1fr;
        }
        .gallery-item.tall .img-frame {
            aspect-ratio: 3 / 2;
        }
        .filter-bar {
            margin-bottom: 3rem;
        }
    }
</style>
