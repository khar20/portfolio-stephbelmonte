---
import ThreeScene from "./ThreeScene.svelte";
---

<section class="hero-section">
    <div class="top-bar container">
        <div class="artist-brand">SB / {new Date().getFullYear()}</div>
        <nav class="skills" aria-label="Disciplines">
            <span class="pill">3D MODELLING</span>
            <span class="pill">SHADING</span>
            <span class="pill">LIGHTING</span>
        </nav>
    </div>

    <div class="center-stage container">
        <div class="graphics-wrapper">
            <div class="astroid-shape" aria-hidden="true"></div>
            <h1 class="artist-name">
                <span class="line">STEPHANI</span>
                <span class="line">BELMONTE</span>
            </h1>
        </div>
    </div>

    <div class="bottom-ui container">
        <div class="role-badge">3D ARTIST</div>
        <div class="actions">
            <button id="about-trigger" class="btn secondary" type="button"
                >ABOUT ME</button
            >
            <a href="#contact" class="btn primary">CONTACT</a>
        </div>
    </div>

    <div
        id="about-overlay"
        class="about-overlay"
        role="dialog"
        aria-modal="true"
        aria-label="About Stephani"
    >
        <div class="about-content">
            <button
                id="about-close"
                class="close-btn"
                type="button"
                aria-label="Close">✕</button
            >
            <span class="about-eyebrow">WHO I AM</span>
            <h2>ABOUT STEPH</h2>
            <p>
                Digital sculptor and visual artist. Exploring the boundaries
                between geometry and emotion. Based in Peru, working globally.
            </p>
            <div class="overlay-socials">
                <a href="#" target="_blank" rel="noopener noreferrer"
                    >INSTA / polaris.s.b</a
                >
                <a href="#" target="_blank" rel="noopener noreferrer"
                    >BEHANCE / sbelmonte</a
                >
            </div>
        </div>
    </div>

    <div class="scene-wrapper" aria-hidden="true">
        <ThreeScene client:load />
    </div>
</section>

<script>
    import { gsap } from "gsap";

    const trigger = document.getElementById("about-trigger");
    const closeBtn = document.getElementById("about-close");
    const overlay = document.getElementById("about-overlay");

    function openOverlay() {
        if (!overlay) return;
        overlay.style.display = "flex";
        gsap.fromTo(overlay, { opacity: 0 }, { opacity: 1, duration: 0.4 });
        document.body.style.overflow = "hidden";
    }

    function closeOverlay() {
        if (!overlay) return;
        gsap.to(overlay, {
            opacity: 0,
            duration: 0.25,
            onComplete: () => {
                overlay.style.display = "none";
                document.body.style.overflow = "";
            },
        });
    }

    trigger?.addEventListener("click", openOverlay);
    closeBtn?.addEventListener("click", closeOverlay);
    overlay?.addEventListener("click", (e) => {
        if (e.target === overlay) closeOverlay();
    });
    document.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && overlay?.style.display === "flex")
            closeOverlay();
    });

    window.addEventListener("load", () => {
        const tl = gsap.timeline({ defaults: { ease: "power3.out" } });
        tl.from(".astroid-shape", {
            scale: 0,
            duration: 1.4,
            ease: "elastic.out(1, 0.5)",
        })
            .from(
                ".line",
                { y: 80, opacity: 0, duration: 0.9, stagger: 0.18 },
                "-=0.9",
            )
            .from(".top-bar", { opacity: 0, y: -10, duration: 0.7 }, "-=0.5")
            .from(".bottom-ui", { opacity: 0, y: 10, duration: 0.7 }, "<");
    });
</script>

<style>
    .hero-section {
        position: relative;
        height: 100vh;
        height: 100dvh;
        width: 100%;
        background-color: #050505;
        overflow: hidden;
        color: white;
    }

    .scene-wrapper {
        position: absolute;
        inset: 0;
        z-index: 1;
        pointer-events: none;
    }

    .top-bar {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-top: clamp(1.5rem, 3vh, 2.5rem);
        z-index: 10;
    }

    .artist-brand {
        font-size: 0.85rem;
        letter-spacing: 0.08em;
        font-weight: 300;
        opacity: 0.8;
    }

    .skills {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
        justify-content: flex-end;
    }

    .pill {
        border: 1px solid rgba(255, 255, 255, 0.4);
        padding: 0.45rem 1rem;
        border-radius: 50px;
        font-size: 0.65rem;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        background: rgba(0, 0, 0, 0.25);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
    }

    .center-stage {
        position: relative;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: flex-start;
        z-index: 5;
        pointer-events: none;
    }

    .graphics-wrapper {
        position: relative;
        display: grid;
        place-items: center;
        margin-left: clamp(0px, 5vw, 5rem);
    }

    .astroid-shape {
        position: absolute;
        width: clamp(260px, 44vw, 600px);
        height: clamp(260px, 44vw, 600px);
        background-color: white;
        clip-path: path(
            "M300,0 C300,165 165,300 0,300 C165,300 300,435 300,600 C300,435 435,300 600,300 C435,300 300,165 300,0"
        );
        z-index: 1;
        transform-origin: center;
    }

    .artist-name {
        position: relative;
        z-index: 2;
        font-family: "Playfair Display", serif;
        font-size: clamp(3.5rem, 8vw, 10rem);
        line-height: 0.85;
        color: white;
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        mix-blend-mode: difference;
        letter-spacing: -0.03em;
    }

    .line {
        display: block;
    }

    .bottom-ui {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-bottom: clamp(1.5rem, 3vh, 2.5rem);
        z-index: 10;
    }

    .role-badge {
        border: 1px solid rgba(255, 255, 255, 0.5);
        padding: 0.55rem 1.75rem;
        border-radius: 50px;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 0.12em;
        backdrop-filter: blur(6px);
        -webkit-backdrop-filter: blur(6px);
    }

    .actions {
        display: flex;
        gap: 0.75rem;
    }

    .btn {
        padding: 0.7rem 1.75rem;
        border-radius: 50px;
        font-size: 0.72rem;
        font-weight: 500;
        cursor: pointer;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        transition: transform 0.2s;
        border: 1px solid transparent;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .btn:hover {
        transform: scale(1.04);
    }

    .btn.secondary {
        background: rgba(0, 0, 0, 0.25);
        border-color: rgba(255, 255, 255, 0.5);
        color: white;
        backdrop-filter: blur(6px);
        -webkit-backdrop-filter: blur(6px);
    }

    .btn.primary {
        background: white;
        color: black;
    }

    .about-overlay {
        position: fixed;
        inset: 0;
        background: rgba(3, 3, 3, 0.92);
        backdrop-filter: blur(14px);
        -webkit-backdrop-filter: blur(14px);
        z-index: 100;
        display: none;
        align-items: center;
        justify-content: center;
        padding: 2rem;
    }

    .about-content {
        max-width: 480px;
        width: 100%;
        position: relative;
    }

    .about-eyebrow {
        font-size: 0.6rem;
        letter-spacing: 0.25em;
        opacity: 0.3;
        display: block;
        margin-bottom: 1.5rem;
    }

    .about-content h2 {
        font-family: "Playfair Display", serif;
        font-size: clamp(2rem, 6vw, 3.5rem);
        font-weight: 700;
        letter-spacing: -0.02em;
        margin-bottom: 1.5rem;
    }

    .about-content p {
        font-size: 1rem;
        line-height: 1.75;
        opacity: 0.65;
        font-weight: 300;
        margin-bottom: 2.5rem;
    }

    .overlay-socials {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .overlay-socials a {
        font-size: 0.75rem;
        letter-spacing: 0.1em;
        opacity: 0.4;
        text-transform: uppercase;
        transition: opacity 0.2s;
    }

    .overlay-socials a:hover {
        opacity: 0.8;
    }

    .close-btn {
        position: absolute;
        top: -3rem;
        right: 0;
        background: none;
        border: 1px solid rgba(255, 255, 255, 0.2);
        color: white;
        font-size: 0.85rem;
        cursor: pointer;
        width: 2.25rem;
        height: 2.25rem;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: border-color 0.2s;
    }

    .close-btn:hover {
        border-color: rgba(255, 255, 255, 0.6);
    }

    @media (max-width: 768px) {
        .center-stage {
            justify-content: center;
        }
        .graphics-wrapper {
            margin-left: 0;
        }
        .skills {
            display: none;
        }
        .bottom-ui {
            flex-direction: column;
            gap: 1rem;
            padding-bottom: 2.5rem;
        }
        .actions {
            width: 100%;
        }
        .btn {
            flex: 1;
        }
    }
</style>
