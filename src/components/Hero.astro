---
import StarfieldBackground from "./StarfieldBackground.svelte";
import ModelViewer from "./ModelViewer.svelte";
---

<section class="hero-section">
    <!-- background -->
    <StarfieldBackground client:load />

    <!-- top bar -->
    <div class="top-bar container">
        <div class="artist-brand">SB / {new Date().getFullYear()}</div>

        <nav class="skills" aria-label="Disciplines">
            <span class="pill">3D MODELLING</span>
            <span class="pill">SHADING</span>
            <span class="pill">LIGHTING</span>
        </nav>
    </div>

    <!-- hero layout -->
    <div class="hero-grid container">
        <!-- LEFT -->
        <div class="left">
            <div class="graphics-wrapper">
                <div class="astroid-shape" aria-hidden="true">
                    <svg viewBox="0 0 200 200" class="asteroid-svg">
                        <path
                            d="M100 0
                            C100 55 55 100 0 100
                            C55 100 100 145 100 200
                            C100 145 145 100 200 100
                            C145 100 100 55 100 0"
                            fill="white"></path>
                    </svg>
                </div>

                <h1 class="artist-name">
                    <span class="line">STEPHANI</span>
                    <span class="line">BELMONTE</span>
                </h1>
            </div>
        </div>

        <!-- RIGHT -->
        <div class="right">
            <ModelViewer client:load />
        </div>
    </div>

    <!-- bottom ui -->
    <div class="bottom-ui container">
        <div class="role-badge">3D ARTIST</div>

        <div class="actions">
            <button id="about-trigger" class="btn secondary" type="button">
                ABOUT ME
            </button>
            <a href="#contact" class="btn primary">CONTACT</a>
        </div>
    </div>

    <!-- about overlay -->
    <div
        id="about-overlay"
        class="about-overlay"
        role="dialog"
        aria-modal="true"
        aria-label="About Stephani"
    >
        <div class="about-content">
            <button
                id="about-close"
                class="close-btn"
                type="button"
                aria-label="Close"
            >
                ✕
            </button>

            <span class="about-eyebrow">WHO I AM</span>
            <h2>ABOUT STEPH</h2>

            <p>
                Digital sculptor and visual artist. Exploring the boundaries
                between geometry and emotion. Based in Peru, working globally.
            </p>

            <div class="overlay-socials">
                <a href="#" target="_blank" rel="noopener noreferrer">
                    INSTA / polaris.s.b
                </a>
                <a href="#" target="_blank" rel="noopener noreferrer">
                    BEHANCE / sbelmonte
                </a>
            </div>
        </div>
    </div>
</section>

<script>
    import { gsap } from "gsap";

    window.addEventListener("load", () => {
        // element refs (safe after load)
        const trigger = document.getElementById("about-trigger");
        const closeBtn = document.getElementById("about-close");
        const overlay = document.getElementById("about-overlay");

        // overlay controls
        function openOverlay() {
            if (!overlay) return;
            overlay.style.display = "flex";
            gsap.fromTo(overlay, { opacity: 0 }, { opacity: 1, duration: 0.4 });
            document.body.style.overflow = "hidden";
        }

        function closeOverlay() {
            if (!overlay) return;

            gsap.to(overlay, {
                opacity: 0,
                duration: 0.25,
                onComplete: () => {
                    overlay.style.display = "none";
                    document.body.style.overflow = "";
                },
            });
        }

        trigger?.addEventListener("click", openOverlay);
        closeBtn?.addEventListener("click", closeOverlay);

        overlay?.addEventListener("click", (e) => {
            if (e.target === overlay) closeOverlay();
        });

        document.addEventListener("keydown", (e) => {
            if (e.key === "Escape" && overlay?.style.display === "flex") {
                closeOverlay();
            }
        });

        // intro animation
        const tl = gsap.timeline({ defaults: { ease: "power3.out" } });

        tl.from(".astroid-shape", {
            scale: 0,
            duration: 1.4,
            ease: "elastic.out(1, 0.5)",
        })
            .from(
                ".line",
                { y: 80, opacity: 0, duration: 0.9, stagger: 0.18 },
                "-=0.9",
            )
            .from(".top-bar", { opacity: 0, y: -10, duration: 0.7 }, "-=0.5")
            .from(".bottom-ui", { opacity: 0, y: 10, duration: 0.7 }, "<");
    });
</script>

<style>
    .hero-section {
        position: relative;
        height: 100vh;
        height: 100dvh;
        width: 100%;
        background-color: #050505;
        overflow: hidden;
        color: white;
    }

    .hero-grid {
        position: relative;
        z-index: 5;

        display: grid;
        grid-template-columns: 1fr 1fr;
        align-items: center;

        height: 100%;
    }

    .left {
        display: flex;
        justify-content: flex-start;
    }

    .right {
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .top-bar {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;

        display: flex;
        justify-content: space-between;
        align-items: center;

        padding-top: clamp(1.5rem, 3vh, 2.5rem);
        z-index: 10;
    }

    .artist-brand {
        font-size: 0.85rem;
        letter-spacing: 0.08em;
        font-weight: 300;
        opacity: 0.8;
    }

    .skills {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
        justify-content: flex-end;
    }

    .pill {
        border: 1px solid rgba(255, 255, 255, 0.4);
        padding: 0.45rem 1rem;
        border-radius: 50px;
        font-size: 0.65rem;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        background: rgba(0, 0, 0, 0.25);
        backdrop-filter: blur(8px);
    }

    .graphics-wrapper {
        position: relative;
        display: grid;
        place-items: center;
    }

    .astroid-shape {
        position: absolute;
        width: clamp(260px, 44vw, 600px);
        height: clamp(260px, 44vw, 600px);
        z-index: 1;
        opacity: 0.95;
        mix-blend-mode: screen;
    }

    .asteroid-svg {
        width: 100%;
        height: 100%;
    }

    .artist-name {
        position: relative;
        z-index: 2;
        font-family: "Playfair Display", serif;
        font-size: clamp(3.5rem, 8vw, 10rem);
        line-height: 0.85;
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        mix-blend-mode: difference;
        letter-spacing: -0.03em;
    }

    .bottom-ui {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;

        display: flex;
        justify-content: space-between;
        align-items: center;

        padding-bottom: clamp(1.5rem, 3vh, 2.5rem);
        z-index: 10;
    }

    .role-badge {
        border: 1px solid rgba(255, 255, 255, 0.5);
        padding: 0.55rem 1.75rem;
        border-radius: 50px;
        font-size: 0.75rem;
        letter-spacing: 0.12em;
    }

    .actions {
        display: flex;
        gap: 0.75rem;
    }

    .btn {
        padding: 0.7rem 1.75rem;
        border-radius: 50px;
        font-size: 0.72rem;
        cursor: pointer;
        text-transform: uppercase;
    }

    .btn.secondary {
        background: rgba(0, 0, 0, 0.25);
        border: 1px solid rgba(255, 255, 255, 0.5);
        color: white;
    }

    .btn.primary {
        background: white;
        color: black;
    }

    .about-overlay {
        position: fixed;
        inset: 0;
        background: rgba(3, 3, 3, 0.92);
        z-index: 100;
        display: none;
        align-items: center;
        justify-content: center;
        padding: 2rem;
    }

    @media (max-width: 768px) {
        .hero-grid {
            grid-template-columns: 1fr;
            text-align: center;
            align-content: center;
            justify-items: center;
            min-height: 100%;
        }

        .left {
            justify-content: center;
        }

        .right {
            margin-top: 2rem;
        }
    }
</style>
